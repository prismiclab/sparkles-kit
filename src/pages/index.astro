---
import BaseLayout from '../layouts/BaseLayout.astro';
import HoloCard from '../components/HoloCard.astro';
import HoloPanel from '../components/HoloPanel.astro';
import PrismTile from '../components/PrismTile.astro';
import PuttyBlob from '../components/PuttyBlob.astro';
import AntigravTile from '../components/AntigravTile.astro';
import ColorSpill from '../components/ColorSpill.astro';
import AuroraText from '../components/AuroraText.astro';
import SpotlightTile from '../components/SpotlightTile.astro';
import TiltTile from '../components/TiltTile.astro';
import StatTile from '../components/StatTile.astro';
import Tabs from '../components/Tabs.astro';
import Progress from '../components/Progress.astro';
import Skeleton from '../components/Skeleton.astro';
import StatusDot from '../components/StatusDot.astro';
import Tooltip from '../components/Tooltip.astro';
import Marquee from '../components/Marquee.astro';
import LiquidTile from '../components/LiquidTile.astro';
import Reveal from '../components/Reveal.astro';
import StaggerChildren from '../components/StaggerChildren.astro';
import PillButton from '../components/PillButton.astro';
import HoloSlider from '../components/HoloSlider.astro';
import HoloToggle from '../components/HoloToggle.astro';
import CodeBlock from '../components/CodeBlock.astro';
---

<BaseLayout
  title="sparkles-kit — drop-in CSS for sparkles, holo edges, rainbow UI"
  description="A small, dependency-free CSS kit for sparkles, rotating holo edges, and aurora-tinted UI. Copy the file, use the classes, ship."
>
  <main class="site-shell">

    <header>
      <p class="site-eyebrow">— sparkles-kit / v0.1</p>
      <h1 class="sk-aurora-line site-h1" data-text="A small kit for sparkles, holo edges, and rainbow UI.">
        A small kit for sparkles, holo edges, and rainbow UI.
      </h1>
      <p class="site-lede">
        One CSS file, no JavaScript required, no framework lock-in. Drop it
        into any project and use the classes below. Built on conic gradients,
        custom properties, and registered <code style="font-family: var(--font-mono); font-size: 14px;">@property</code> angles
        — it stays smooth because the browser owns the animation.
      </p>

      <div style="margin-top: 32px; display: flex; gap: 12px; flex-wrap: wrap;">
        <PillButton variant="primary" as="a" href="#install">install</PillButton>
        <PillButton variant="ghost" as="a" href="#components">components</PillButton>
        <PillButton variant="holo" as="a" href="https://github.com/prismiclab/sparkles-kit">github</PillButton>
      </div>
    </header>

    {/* ============================================================ */}
    {/* Install                                                       */}
    {/* ============================================================ */}
    <h2 class="site-h2" id="install">Install</h2>
    <p class="site-section-note">
      Two options. Pick whichever matches your project. Both deliver
      the same classes.
    </p>

    <div class="site-grid-2">
      <HoloPanel>
        <p class="site-eyebrow">option a — vanilla</p>
        <p style="margin: 12px 0 16px; color: var(--sk-text-secondary); font-size: 14px;">
          Copy <code>sparkles-kit.css</code> into your project and link it
          from your HTML. Works with any framework or none.
        </p>
        <CodeBlock code={`<link rel="stylesheet" href="/sparkles-kit.css" />`} />
      </HoloPanel>

      <HoloPanel>
        <p class="site-eyebrow">option b — astro / vite / next</p>
        <p style="margin: 12px 0 16px; color: var(--sk-text-secondary); font-size: 14px;">
          Drop the file in <code>src/styles/</code> and import it once
          from your root layout.
        </p>
        <CodeBlock code={`import '../styles/sparkles-kit.css';`} lang="js" />
      </HoloPanel>
    </div>

    {/* ============================================================ */}
    {/* Sparkles + aurora background                                  */}
    {/* ============================================================ */}
    <h2 class="site-h2" id="components">Sparkles + aurora</h2>
    <p class="site-section-note">
      The whole page already has both running — those are the
      drifting blobs and the static-but-pulsing dots in the background.
      Drop these once into your root layout; they fix to the viewport.
    </p>

    <CodeBlock code={`<!-- aurora blobs (z:0) -->
<div class="sk-aurora-layer" aria-hidden="true">
  <div class="sk-blob sk-blob-peach"></div>
  <div class="sk-blob sk-blob-amber"></div>
  <div class="sk-blob sk-blob-mint"></div>
  <div class="sk-blob sk-blob-indigo"></div>
  <div class="sk-blob sk-blob-violet"></div>
  <div class="sk-blob sk-blob-rose"></div>
</div>
<div class="sk-aurora-veil" aria-hidden="true"></div>

<!-- sparkle layer (z:2) — one .sk-sparkle per dot -->
<div class="sk-sparkle-layer" aria-hidden="true">
  <span class="sk-sparkle sk-sparkle-ambient"
        style="left: 12%; top: 33%; width: 2px; height: 2px;
               --sk-c: #C5759A; --sk-base-opacity: 0.6;
               --sk-drift-x: 30px; --sk-drift-y: -20px;"></span>
  <!-- ...repeat for each sparkle... -->
</div>`} />

    {/* ============================================================ */}
    {/* Pill buttons                                                  */}
    {/* ============================================================ */}
    <h2 class="site-h2">Pill buttons</h2>
    <p class="site-section-note">
      Three variants. <code>.sk-pill</code> alone is the warm-peach default;
      <code>.sk-pill-ghost</code> is transparent with a hairline border;
      <code>.sk-pill-holo</code> wraps a rotating rainbow ring that blooms on hover.
    </p>

    <div class="site-demo">
      <PillButton>primary</PillButton>
      <PillButton variant="ghost">ghost</PillButton>
      <PillButton variant="holo">holo on hover</PillButton>
    </div>

    <CodeBlock code={`<button class="sk-pill">primary</button>
<button class="sk-pill sk-pill-ghost">ghost</button>
<button class="sk-pill sk-pill-holo">holo on hover</button>`} />

    {/* ============================================================ */}
    {/* Holo card                                                     */}
    {/* ============================================================ */}
    <h2 class="site-h2">Holo card</h2>
    <p class="site-section-note">
      A rotating 1px conic-gradient border around a glass-like surface.
      Add <code>.sk-holo-glow</code> for an outer bloom that intensifies on hover.
      Hover the right one.
    </p>

    <div class="site-grid-2" style="margin-bottom: 16px;">
      <HoloCard>
        <p class="site-eyebrow">/ sk-holo-card</p>
        <h3 style="font-family: var(--font-display); font-size: 22px; margin: 8px 0; letter-spacing: -0.015em;">
          Quiet by default
        </h3>
        <p style="color: var(--sk-text-secondary); font-size: 14px; line-height: 1.6;">
          The edge gradient sits at 32% opacity until you hover. No layout shift.
          Background also deepens by one shade on hover.
        </p>
      </HoloCard>

      <HoloCard glow>
        <p class="site-eyebrow">/ sk-holo-card.sk-holo-glow</p>
        <h3 style="font-family: var(--font-display); font-size: 22px; margin: 8px 0; letter-spacing: -0.015em;">
          With outer bloom
        </h3>
        <p style="color: var(--sk-text-secondary); font-size: 14px; line-height: 1.6;">
          Same card, but a heavily blurred conic gradient bleeds outward
          behind it. Hover lifts the bloom from 22% to 40% opacity.
        </p>
      </HoloCard>
    </div>

    <CodeBlock code={`<div class="sk-holo-card">…content…</div>

<div class="sk-holo-card sk-holo-glow">…content with outer bloom…</div>`} />

    {/* ============================================================ */}
    {/* Holo panel                                                    */}
    {/* ============================================================ */}
    <h2 class="site-h2">Holo hover panel</h2>
    <p class="site-section-note">
      Lighter than the card — no border ring, just a soft conic
      gradient that blooms behind the panel on hover. Good for grid tiles
      and feature lists. Hover any of these.
    </p>

    <div class="site-grid-2" style="margin-bottom: 16px;">
      <HoloPanel>
        <p class="site-eyebrow">001 / discover</p>
        <h3 style="font-family: var(--font-display); font-size: 20px; margin: 6px 0;">Sparkles</h3>
        <p style="color: var(--sk-text-secondary); font-size: 14px;">Drifting, pulsing dots in six aurora hues.</p>
      </HoloPanel>
      <HoloPanel>
        <p class="site-eyebrow">002 / wrap</p>
        <h3 style="font-family: var(--font-display); font-size: 20px; margin: 6px 0;">Holo edges</h3>
        <p style="color: var(--sk-text-secondary); font-size: 14px;">Conic-gradient borders that rotate via @property.</p>
      </HoloPanel>
      <HoloPanel>
        <p class="site-eyebrow">003 / press</p>
        <h3 style="font-family: var(--font-display); font-size: 20px; margin: 6px 0;">Pill buttons</h3>
        <p style="color: var(--sk-text-secondary); font-size: 14px;">Three variants. Holo glow only on demand.</p>
      </HoloPanel>
    </div>

    <CodeBlock code={`<div class="sk-holo-panel">…content…</div>`} />

    {/* ============================================================ */}
    {/* Prism tile                                                    */}
    {/* ============================================================ */}
    <h2 class="site-h2">Prism tile</h2>
    <p class="site-section-note">
      Holographic-foil background. Layered diagonal aurora stripe (animated),
      white caustic glints, and a soft conic edge ring. Three flavors:
      <code>.sk-prism-tile</code> alone is the still ambient version,
      <code>.sk-prism-sweep</code> adds an iridescent sweep on hover,
      <code>.sk-prism-festival</code> turns up the saturation and crosses
      a second dispersion stripe — full festival energy. JS-free.
    </p>

    <div class="site-grid-2" style="margin-bottom: 16px;">
      <PrismTile>
        <p class="site-eyebrow">/ sk-prism-tile</p>
        <h3 style="font-family: var(--font-display); font-size: 22px; margin: 8px 0; letter-spacing: -0.015em;">
          Still
        </h3>
        <p style="color: var(--sk-text-secondary); font-size: 14px; line-height: 1.6;">
          Ambient iridescent foil. Slow background-position animation
          drifts the rainbow stripe across the surface.
        </p>
      </PrismTile>

      <PrismTile variant="sweep">
        <p class="site-eyebrow">/ + sk-prism-sweep</p>
        <h3 style="font-family: var(--font-display); font-size: 22px; margin: 8px 0; letter-spacing: -0.015em;">
          Sweep on hover
        </h3>
        <p style="color: var(--sk-text-secondary); font-size: 14px; line-height: 1.6;">
          Same base, plus a second iridescent stripe that sweeps from
          left to right when the cursor enters. Hover me.
        </p>
      </PrismTile>
    </div>

    <div style="margin-bottom: 12px;">
      <PrismTile variant="festival">
        <p class="site-eyebrow">/ + sk-prism-festival</p>
        <h3 style="font-family: var(--font-display); font-size: 26px; margin: 8px 0; letter-spacing: -0.015em;">
          Festival energy.
        </h3>
        <p style="color: var(--sk-text-secondary); font-size: 14px; line-height: 1.65; max-width: 60ch;">
          Two crossing dispersion stripes, white caustic glints,
          full saturation. The Pink-Floyd-prism-meets-holo-foil flavor.
          Use sparingly — it commands the page.
        </p>
      </PrismTile>
    </div>

    <CodeBlock code={`<div class="sk-prism-tile">…still ambient…</div>

<div class="sk-prism-tile sk-prism-sweep">…sweep on hover…</div>

<div class="sk-prism-tile sk-prism-festival">…festival energy…</div>`} />

    {/* ============================================================ */}
    {/* Putty blob                                                    */}
    {/* ============================================================ */}
    <h2 class="site-h2">Putty blob</h2>
    <p class="site-section-note">
      Inspired by glittery "smart putty". The shape morphs slowly via
      animated <code>border-radius</code>; specular + shadow inserts
      give it volume; a glitter sub-layer twinkles on top. Two flavors:
      emerald (default) and aurora (cycles the palette via a registered
      <code>@property</code> hue angle). Hover for a subtle wobble.
    </p>

    <div class="site-demo" style="gap: 48px;">
      <PuttyBlob />
      <PuttyBlob variant="aurora" />
    </div>

    <CodeBlock code={`<div class="sk-putty-blob"></div>

<div class="sk-putty-blob sk-putty-aurora"></div>`} />

    {/* ============================================================ */}
    {/* Antigravity tile                                              */}
    {/* ============================================================ */}
    <h2 class="site-h2">Antigravity tile</h2>
    <p class="site-section-note">
      Floating glass in the Linear-look idiom — backdrop-blur frosted
      glass, animated specular hairline ring, aurora underglow welling
      up from below, drifting particles inside. Bobs ~3px at rest;
      hover lifts 8px and intensifies the underglow + edge highlight.
      Add <code>.sk-antigrav-grid</code> for a subtle 24px dotted grid
      behind the particles.
    </p>

    <div class="site-grid-2" style="gap: 24px; margin-bottom: 16px;">
      <AntigravTile>
        <p class="site-eyebrow">/ sk-antigrav-tile</p>
        <h3 style="font-family: var(--font-display); font-size: 22px; margin: 8px 0; letter-spacing: -0.015em;">
          Suspended.
        </h3>
        <p style="color: var(--sk-text-secondary); font-size: 14px; line-height: 1.6;">
          Bottom-up aurora wash + drifting particles. Backdrop-blur
          means whatever sits behind the tile (the aurora layer here)
          softens through the glass.
        </p>
      </AntigravTile>

      <AntigravTile grid>
        <p class="site-eyebrow">/ + sk-antigrav-grid</p>
        <h3 style="font-family: var(--font-display); font-size: 22px; margin: 8px 0; letter-spacing: -0.015em;">
          With dotted grid.
        </h3>
        <p style="color: var(--sk-text-secondary); font-size: 14px; line-height: 1.6;">
          Same tile, plus a faint 24px dot pattern layered behind the
          particles. The Linear-look move that adds structure without
          shouting.
        </p>
      </AntigravTile>
    </div>

    <p class="site-section-note" style="margin-bottom: 16px;">
      Bento layout — three tiles of varying weight, the kind of grid
      you see all over linear.app and vercel.com.
    </p>

    <div style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 16px; margin-bottom: 12px;">
      <AntigravTile grid>
        <p class="site-eyebrow">001 / hero</p>
        <h3 style="font-family: var(--font-display); font-size: 24px; margin: 8px 0; letter-spacing: -0.02em;">
          Wide tile, more weight.
        </h3>
        <p style="color: var(--sk-text-secondary); font-size: 14px; line-height: 1.6;">
          The big tile carries the headline; the smaller ones support.
        </p>
      </AntigravTile>
      <AntigravTile>
        <p class="site-eyebrow">002</p>
        <h3 style="font-family: var(--font-display); font-size: 18px; margin: 8px 0; letter-spacing: -0.015em;">
          Support.
        </h3>
      </AntigravTile>
      <AntigravTile>
        <p class="site-eyebrow">003</p>
        <h3 style="font-family: var(--font-display); font-size: 18px; margin: 8px 0; letter-spacing: -0.015em;">
          Detail.
        </h3>
      </AntigravTile>
    </div>

    <CodeBlock code={`<div class="sk-antigrav-tile">…content…</div>

<div class="sk-antigrav-tile sk-antigrav-grid">…with dotted grid…</div>`} />

    {/* ============================================================ */}
    {/* Grid background                                               */}
    {/* ============================================================ */}
    <h2 class="site-h2">Grid background</h2>
    <p class="site-section-note">
      Fixed dotted (default) or lined grid overlay. Sits between the
      aurora veil and the sparkles in the z-stack so blobs glow
      through it. Mount once in your layout — same shape as
      <code>.sk-aurora-layer</code> and <code>.sk-sparkle-layer</code>.
      It's already painting subtly behind this whole page.
    </p>

    <CodeBlock code={`<!-- once per page in your root layout -->
<div class="sk-grid-bg" aria-hidden="true"></div>

<!-- or 1px lines instead of dots -->
<div class="sk-grid-bg sk-grid-lined" aria-hidden="true"></div>`} />

    {/* ============================================================ */}
    {/* Color spill                                                   */}
    {/* ============================================================ */}
    <h2 class="site-h2">Color spill</h2>
    <p class="site-section-note">
      Tile-sized aurora accent blob — different from <code>.sk-blob</code>
      (which is fullscreen). Use behind hero text, beside cards, at
      section transitions. Six color modifiers; add
      <code>.sk-spill-drift</code> for slow movement.
    </p>

    <div class="site-demo" style="position: relative; min-height: 220px; overflow: hidden;">
      <ColorSpill color="peach"  size={200} drift style="position:absolute; top:-40px; left:-40px;" />
      <ColorSpill color="rose"   size={180} drift style="position:absolute; top:60px; left:140px;" />
      <ColorSpill color="violet" size={220} drift style="position:absolute; top:-20px; left:340px;" />
      <ColorSpill color="indigo" size={200} drift style="position:absolute; top:80px; left:540px;" />
      <ColorSpill color="mint"   size={180} drift style="position:absolute; top:-30px; right:140px;" />
      <ColorSpill color="amber"  size={200} drift style="position:absolute; top:60px; right:-40px;" />
      <p style="position: relative; z-index: 5; text-align: center; font-family: var(--font-display); font-size: 36px; letter-spacing: -0.025em; color: var(--sk-text-primary);">
        all six hues, scattered.
      </p>
    </div>

    <CodeBlock code={`<div class="sk-color-spill sk-spill-violet"
     style="position: absolute; top: 80px; left: 40%;"></div>

<!-- or with slow drift animation -->
<div class="sk-color-spill sk-spill-mint sk-spill-drift"></div>`} />

    {/* ============================================================ */}
    {/* Slider + toggle                                               */}
    {/* ============================================================ */}
    <h2 class="site-h2">Slider + toggle</h2>
    <p class="site-section-note">
      Cross-browser styled native inputs. The slider track paints
      the full aurora; the toggle swaps to a gradient when checked.
    </p>

    <div class="site-demo" style="flex-direction: column; align-items: stretch; gap: 32px;">
      <div>
        <label style="display: block; font-family: var(--font-mono); font-size: 13px; color: var(--sk-text-secondary); margin-bottom: 12px;">
          / sk-slider
        </label>
        <HoloSlider value={62} />
      </div>

      <div style="display: flex; align-items: center; gap: 16px;">
        <label style="font-family: var(--font-mono); font-size: 13px; color: var(--sk-text-secondary);">
          / sk-toggle
        </label>
        <HoloToggle />
        <HoloToggle checked />
      </div>
    </div>

    <CodeBlock code={`<input type="range" class="sk-slider" min="0" max="100" value="62" />

<label class="sk-toggle">
  <input type="checkbox" />
  <span class="sk-toggle-track"><span class="sk-toggle-thumb"></span></span>
</label>`} />

    {/* ============================================================ */}
    {/* Aurora-line headline                                          */}
    {/* ============================================================ */}
    <h2 class="site-h2">Aurora-line headline</h2>
    <p class="site-section-note">
      A cream-white headline with a slowly-rotating conic-gradient
      duplicate clipped to the text. Reads like "shimmer on metal,
      not rainbow text". Pass the same string twice — once as content,
      once via <code>data-text</code>.
    </p>

    <div class="site-demo">
      <span class="sk-aurora-line" style="font-family: var(--font-display); font-size: clamp(32px, 5vw, 56px); letter-spacing: -0.025em;" data-text="hello, holo.">
        hello, holo.
      </span>
    </div>

    <CodeBlock code={`<h1 class="sk-aurora-line" data-text="hello, holo.">
  hello, holo.
</h1>`} />

    {/* ============================================================ */}
    {/* Avatar                                                        */}
    {/* ============================================================ */}
    <h2 class="site-h2">Aurora ring avatar</h2>
    <p class="site-section-note">
      Instagram-story-style ring around a circular photo well.
      Falls back to initials if no image is set.
    </p>

    <div class="site-demo">
      <div class="sk-avatar">
        <div class="sk-avatar-ring"></div>
        <div class="sk-avatar-photo">nw</div>
      </div>
    </div>

    <CodeBlock code={`<div class="sk-avatar">
  <div class="sk-avatar-ring"></div>
  <div class="sk-avatar-photo">
    <!-- <img src="..."/> or initials fallback -->
    nw
  </div>
</div>`} />

    {/* ============================================================ */}
    {/* Aurora text                                                   */}
    {/* ============================================================ */}
    <h2 class="site-h2">Aurora text</h2>
    <p class="site-section-note">
      Static aurora-gradient text utility. Complements the
      slowly-rotating <code>.sk-aurora-line</code> shimmer — use this
      for big stat numbers, hero accents, or anywhere you want a
      single static rainbow tint on text.
    </p>
    <div class="site-demo">
      <span style="font-family: var(--font-display); font-size: clamp(48px, 8vw, 96px); letter-spacing: -0.03em; font-weight: 500;">
        <AuroraText>infinity.</AuroraText>
      </span>
    </div>
    <CodeBlock code={`<h1 class="sk-aurora-text">infinity.</h1>`} />

    {/* ============================================================ */}
    {/* Liquid tile                                                   */}
    {/* ============================================================ */}
    <h2 class="site-h2">Liquid tile</h2>
    <p class="site-section-note">
      Holographic-foil flow — pastel pink/blue/violet/peach/mint
      radial blobs drift across the tile via animated
      <code>background-position</code>. Plus a glossy specular on
      top for the "wet plastic" sheen. The Pinterest-aesthetic
      iridescent vibe. Two flavors: pastel (default, light substrate
      with dark text) and dark (uses the kit's aurora tokens on the
      kit's dark substrate).
    </p>

    <div class="site-grid-2" style="margin-bottom: 12px;">
      <LiquidTile>
        <p class="site-eyebrow" style="color: rgba(26,20,25,0.55);">/ sk-liquid-tile</p>
        <h3 style="font-family: var(--font-display); font-size: 26px; margin: 8px 0; letter-spacing: -0.02em; color: #1a1419;">
          Iridescent.
        </h3>
        <p style="font-size: 14px; line-height: 1.6; color: rgba(26,20,25,0.72);">
          The colors flow on a 28-second cycle. No two frames look
          the same — the tile feels alive without being noisy.
        </p>
      </LiquidTile>

      <LiquidTile variant="dark">
        <p class="site-eyebrow">/ + sk-liquid-dark</p>
        <h3 style="font-family: var(--font-display); font-size: 26px; margin: 8px 0; letter-spacing: -0.02em;">
          Same flow, dark mode.
        </h3>
        <p style="color: var(--sk-text-secondary); font-size: 14px; line-height: 1.6;">
          For UIs that stay on the dark substrate. Uses the kit's
          aurora palette tokens, so it retones when you swap them.
        </p>
      </LiquidTile>
    </div>

    <CodeBlock code={`<div class="sk-liquid-tile">…content…</div>

<div class="sk-liquid-tile sk-liquid-dark">…content…</div>`} />

    {/* ============================================================ */}
    {/* Spotlight tile                                                */}
    {/* ============================================================ */}
    <h2 class="site-h2">Spotlight tile</h2>
    <p class="site-section-note">
      Cursor-tracked radial highlight. Hover over the tile and the
      glow follows your pointer. Needs <code>sparkles-kit.js</code> —
      the script sets <code>--sk-mx</code> / <code>--sk-my</code> on
      <code>pointermove</code>.
    </p>
    <div class="site-grid-2" style="margin-bottom: 12px;">
      <SpotlightTile>
        <p class="site-eyebrow">/ sk-spotlight-tile</p>
        <h3 style="font-family: var(--font-display); font-size: 22px; margin: 8px 0; letter-spacing: -0.015em;">
          Hover to spotlight.
        </h3>
        <p style="color: var(--sk-text-secondary); font-size: 14px; line-height: 1.6;">
          Move your cursor — the glow follows. The tile border also
          warms up in the section accent color.
        </p>
      </SpotlightTile>
      <SpotlightTile>
        <p class="site-eyebrow">/ same primitive</p>
