---
import '../styles/site.css';
import Sparkles from '../components/Sparkles.astro';
import GridBg from '../components/GridBg.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'A small drop-in CSS kit for sparkles, holo edges, and rainbow UI.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0A0A0A" />
    <meta name="color-scheme" content="dark" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400;500&display=swap"
    />
  </head>
  <body>
    <!-- Aurora background blobs (kit primitive #1) -->
    <div class="sk-aurora-layer" aria-hidden="true">
      <div class="sk-blob sk-blob-peach"></div>
      <div class="sk-blob sk-blob-amber"></div>
      <div class="sk-blob sk-blob-mint"></div>
      <div class="sk-blob sk-blob-indigo"></div>
      <div class="sk-blob sk-blob-violet"></div>
      <div class="sk-blob sk-blob-rose"></div>
    </div>
    <div class="sk-aurora-veil" aria-hidden="true"></div>

    <!-- Subtle dotted grid (kit primitive — Linear-look structure) -->
    <GridBg variant="dotted" />

    <!-- Subtle film grain — cinematic finish on the dark base -->
    <div class="sk-noise-overlay" aria-hidden="true"></div>

    <!-- Sparkles (kit primitive #2) -->
    <Sparkles count={32} />

    <slot />

    <!-- Optional behavior layer (interactive primitives: spotlight, tilt, cmdk) -->
    <script src={`${import.meta.env.BASE_URL}sparkles-kit.js`} is:inline defer></script>
  </body>
</html>
