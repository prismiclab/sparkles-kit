---
/* SVG filter definitions for .sk-liquid-tile.
   Mount once per page (typically in your root layout). The
   feTurbulence + feDisplacementMap pair produces the wavy fluid
   distortion; the SMIL animate on baseFrequency lets the
   distortion evolve over 22s for a "live liquid" feel.

   Without this snippet, .sk-liquid-tile still renders — just
   without the wavy distortion (graceful fallback). */
---

<svg
  class="sk-liquid-defs"
  aria-hidden="true"
  focusable="false"
  width="0"
  height="0"
  style="position:absolute; width:0; height:0; overflow:hidden;"
>
  <defs>
    <filter id="sk-liquid-distort" x="-20%" y="-20%" width="140%" height="140%">
      <feTurbulence
        type="fractalNoise"
        baseFrequency="0.008 0.014"
        numOctaves="2"
        seed="2"
        result="turb"
      >
        <animate
          attributeName="baseFrequency"
          dur="22s"
          values="0.008 0.014; 0.012 0.020; 0.008 0.014"
          repeatCount="indefinite"
        />
      </feTurbulence>
      <feDisplacementMap in="SourceGraphic" in2="turb" scale="55" />
    </filter>
  </defs>
</svg>
