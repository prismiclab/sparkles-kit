---
interface Props {
  count?: number;
  spread?: number; // fan width in degrees, default 140
  height?: number;
  width?: number;
  seed?: number;
  class?: string;
}

const {
  count = 11,
  spread = 140,
  height = 200,
  width = 22,
  seed = 7331,
  class: className = '',
} = Astro.props;

const palette = ['#D97757', '#C5759A', '#8E7FB8', '#6B8DC9', '#7FB69E', '#D9B377'];

// Deterministic PRNG so SSR + hydration agree.
const rng = (s: number) => {
  let x = s;
  return () => {
    x = (x * 9301 + 49297) % 233280;
    return x / 233280;
  };
};
const r = rng(seed);

const fibers = Array.from({ length: count }, (_, i) => {
  // Fan distributed over `spread`, centered at 180deg
  // (which means the fiber points UP given .sk-fiber's default orientation).
  const t = count === 1 ? 0.5 : i / (count - 1);
  const offset = (t - 0.5) * spread;
  const rot = 180 + offset;
  return {
    rot,
    color: palette[i % palette.length],
    pulseDur: 1.8 + r() * 1.8,
    delay: -r() * 3,
  };
});
---

<div
  class={`sk-glow-stick ${className}`.trim()}
  data-sk-glow-stick
  style={`width: ${width}px; height: ${height}px;`}
>
  <div class="sk-glow-stick-handle"></div>
  <div class="sk-glow-stick-tip">
    {fibers.map((f) => (
      <span
        class="sk-fiber"
        style={`
          --sk-rot: ${f.rot.toFixed(2)}deg;
          --sk-c: ${f.color};
          --sk-pulse-dur: ${f.pulseDur.toFixed(2)}s;
          --sk-delay: ${f.delay.toFixed(2)}s;
        `}
      ></span>
    ))}
  </div>
</div>
