---
interface Props {
  count?: number;
  size?: number;
  seed?: number;
  class?: string;
}

const { count = 48, size = 240, seed = 4127, class: className = '' } = Astro.props;

const auroraVars = [
  '#D97757', // peach
  '#C5759A', // rose
  '#8E7FB8', // violet
  '#6B8DC9', // indigo
  '#7FB69E', // mint
  '#D9B377', // amber
];

// Deterministic PRNG so SSR + hydration agree.
const rng = (s: number) => {
  let x = s;
  return () => {
    x = (x * 9301 + 49297) % 233280;
    return x / 233280;
  };
};
const r = rng(seed);

const fibers = Array.from({ length: count }, (_, i) => ({
  rot: (i * 360) / count + (r() - 0.5) * 3, // even spread + small jitter
  color: auroraVars[i % auroraVars.length],
  pulseDur: 2.2 + r() * 2.4,
  delay: -r() * 4,
}));
---

<div class={`sk-fiber-burst ${className}`.trim()} style={`width: ${size}px; height: ${size}px;`}>
  {fibers.map((f) => (
    <span
      class="sk-fiber"
      style={`
        --sk-rot: ${f.rot.toFixed(2)}deg;
        --sk-c: ${f.color};
        --sk-pulse-dur: ${f.pulseDur.toFixed(2)}s;
        --sk-delay: ${f.delay.toFixed(2)}s;
      `}
    ></span>
  ))}
</div>
